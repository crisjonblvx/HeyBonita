# Server-side auth (required)
BONITACORE_SERVICE_TOKEN=

# Chat provider (required: choose one)
# Option A: Ollama
BONITA_BRAIN_PROVIDER=ollama
BONITA_BRAIN_URL=http://localhost:11434
BONITA_BRAIN_MODEL=mistral

# Option B: Anthropic
# BONITA_BRAIN_PROVIDER=anthropic
# BONITA_BRAIN_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=

# Supabase (optional but recommended for knowledge + conversation persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Knowledge ingest / cron (recommended for production knowledge feeds)
BONITA_INGEST_SECRET=
CRON_SECRET=

# Providers used by other endpoints (optional unless you use those routes)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

STABILITY_API_KEY=
STABILITY_MODEL=stable-diffusion-xl-1024-v1-0

LUMA_API_KEY=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

NEWSAPI_KEY=

# Storage connectors (optional)
BLOB_READ_WRITE_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Misc (optional)
ALLOWED_SERVICE_TOKENS=
CORE_NAME=bonita-core
CORE_VERSION=v1
SMITHSONIAN_API_KEY=
HF_TOKEN=
VERCEL_URL=
BONITACORE_BASE_URL=
NEXT_PUBLIC_APP_URL=

# Client-side (ONLY if you intentionally expose the service token to the browser; not recommended)
NEXT_PUBLIC_BONITA_SERVICE_TOKEN=
# Example Bonita environment configuration (do not commit real keys)

# Supabase — bonita-data-layer
SUPABASE_URL=https://kkripdeolrxqigkopwlq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Service token auth — these must match each other
BONITACORE_SERVICE_TOKEN=bonita-dev-2026
NEXT_PUBLIC_BONITA_SERVICE_TOKEN=bonita-dev-2026

# ---------------------------------------------------------------------------
# Bonita's brain — three modes (set BONITA_BRAIN_PROVIDER + one of the below)
# Bonita's identity, voice, RAG, and prompts stay the same; only the engine swaps.
# ---------------------------------------------------------------------------

# Mode 1: Ollama (local development)
BONITA_BRAIN_PROVIDER=ollama
BONITA_BRAIN_URL=http://localhost:11434
BONITA_BRAIN_MODEL=qwen2.5:32b

# Mode 2: Anthropic Claude (production interim — swap when ready)
# BONITA_BRAIN_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# BONITA_BRAIN_MODEL=claude-sonnet-4-20250514

# Mode 3: Self-hosted Ollama (production final — future)
# BONITA_BRAIN_PROVIDER=ollama
# BONITA_BRAIN_URL=https://bonita-gpu.contentcreators.life
# BONITA_BRAIN_MODEL=bonita-v1-70b

